rule scenicplush5mu2regulonqcpseudobulks:
  input:
    indir="ataccistopic2runscenicpluspipeline/{name}",
    done="ataccistopic2runscenicpluspipeline/{name}.done",
  output:
    genefile="scenicplush5mu2regulonqcpseudobulks/{name}_gene.txt.gz",
    regionfile="scenicplush5mu2regulonqcpseudobulks/{name}_region.txt.gz",
  wildcard_constraints:
    name="[^/]+",
  params:
    obscfg=config['scrnah5adduplicateobs'],
    cfg=config['scenicplush5mu2regulonqcpseudobulks'],
  shell:
    """
    outdir=$(dirname "{output.genefile}")

    # gene
    CMD="scenicplush5mu2regulonqcpseudobulks"
    [ "{params.cfg[condaenv]}" != "None" ] && CMD+=" -e {params.cfg[condaenv]}"
    CMD+=" -d $outdir"
    CMD+=" -b {wildcards.name}_gene"
    CMD+=" -l scRNA_counts:{params.obscfg[key]}"
    CMD+=" -k {params.cfg[modkey_gene]}"
    CMD+=" -m {params.cfg[nsample]}"
    CMD+=" -n {params.cfg[nbulk]}"
    CMD+=" -s {params.cfg[seed]}"
    CMD+=" -- {input.indir}/scplusmdata.h5mu"

    echo "Start running: $CMD"
    eval "$CMD"
    echo "Finish running: $CMD"


    # region
    CMD="scenicplush5mu2regulonqcpseudobulks"
    [ "{params.cfg[condaenv]}" != "None" ] && CMD+=" -e {params.cfg[condaenv]}"
    CMD+=" -d $outdir"
    CMD+=" -b {wildcards.name}_region"
    CMD+=" -l scATAC_counts:{params.obscfg[key]}"
    CMD+=" -k {params.cfg[modkey_region]}"
    CMD+=" -m {params.cfg[nsample]}"
    CMD+=" -n {params.cfg[nbulk]}"
    CMD+=" -s {params.cfg[seed]}"
    CMD+=" -- {input.indir}/scplusmdata.h5mu"

    echo "Start running: $CMD"
    eval "$CMD"
    echo "Finish running: $CMD"
    """

rule scenicplusunstxt2generegionfeaturemap:
  input:
    indir="mudatah5mu2unstxt/{name}",
    done="mudatah5mu2unstxt/{name}.done",
  output:
    outdir=directory("scenicplusunstxt2generegionfeaturemap/{name}"),
    done="scenicplusunstxt2generegionfeaturemap/{name}.done",
  wildcard_constraints:
    name="[^/]+",
  params:
    cfg=config['scenicplusunstxt2generegionfeaturemap'],
  shell:
    """
    # direct file
    directfile="{input.indir}/{wildcards.name}_direct_e_regulon_metadata.txt.gz"
    fname=$(basename $directfile .txt.gz)
    CMD="scenicplusunstxt2generegionfeaturemap"
    [ "{params.cfg[condaenv]}" != "None" ] && CMD+=" -e {params.cfg[condaenv]}"
    CMD+=" -d {output.outdir}"
    CMD+=" -b $fname"
    CMD+=" -s {params.cfg[src]}"
    CMD+=" -t {params.cfg[target]}"
    CMD+=" -- $directfile"

    echo "Start running: $CMD"
    eval "$CMD"
    echo "Finish running: $CMD"

    extendfile="{input.indir}/{wildcards.name}_extended_e_regulon_metadata.txt.gz"
    fname=$(basename $extendfile .txt.gz)
    CMD="scenicplusunstxt2generegionfeaturemap"
    [ "{params.cfg[condaenv]}" != "None" ] && CMD+=" -e {params.cfg[condaenv]}"
    CMD+=" -d {output.outdir}"
    CMD+=" -b $fname"
    CMD+=" -s {params.cfg[src]}"
    CMD+=" -t {params.cfg[target]}"
    CMD+=" -- $extendfile"

    echo "Start running: $CMD"
    eval "$CMD"
    echo "Finish running: $CMD"

    touch {output.done}
    """

rule scenicplusregulonpseudobulks2correlation:
  input:
    genefile="scenicplush5mu2regulonqcpseudobulks/{name}_gene.txt.gz",
    regionfile="scenicplush5mu2regulonqcpseudobulks/{name}_region.txt.gz",
    featuremapdir="scenicplusunstxt2generegionfeaturemap/{name}",
    featuremapdone="scenicplusunstxt2generegionfeaturemap/{name}.done",
  output:
    outfile="scenicplusregulonpseudobulks2correlation/{name}.txt.gz",
  wildcard_constraints:
    name="[^/]+",
  params:
    mapcfg=config['scenicplusunstxt2generegionfeaturemap'],
    cfg=config['scenicplusregulonpseudobulks2correlation'],
  shell:
    """
    outdir=$(dirname "{output.outfile}")

    # gene
    CMD="scenicplusregulonpseudobulks2correlation"
    [ "{params.cfg[condaenv]}" != "None" ] && CMD+=" -e {params.cfg[condaenv]}"
    CMD+=" -d $outdir"
    CMD+=" -b {wildcards.name}"
    CMD+=" -g {input.genefile}"
    CMD+=" -r {input.regionfile}"
    CMD+=" -m {input.featuremapdir}/{wildcards.name}_direct_e_regulon_metadata.txt.gz"
    CMD+=" -s {params.mapcfg[src]}"
    CMD+=" -t {params.mapcfg[target]}"

    echo "Start running: $CMD"
    eval "$CMD"
    echo "Finish running: $CMD"
    """

rule scenicplusreguloncorrelation2subsetfeature:
  input:
    infile="scenicplusregulonpseudobulks2correlation/{name}.txt.gz",
    metadir="mudatah5mu2unstxt/{name}",
    metadone="mudatah5mu2unstxt/{name}.done",
  output:
    outfile="scenicplusreguloncorrelation2subsetfeature/{name}.txt.gz",
  wildcard_constraints:
    name="[^/]+",
  params:
    mapcfg=config['scenicplusunstxt2generegionfeaturemap'],
    cfg=config['scenicplusreguloncorrelation2subsetfeature'],
  shell:
    """
    outdir=$(dirname "{output.outfile}")

    # gene
    CMD="scenicplusreguloncorrelation2subsetfeature"
    [ "{params.cfg[condaenv]}" != "None" ] && CMD+=" -e {params.cfg[condaenv]}"
    CMD+=" -d $outdir"
    CMD+=" -b {wildcards.name}"
    CMD+=" -A {params.mapcfg[src]}"
    CMD+=" -B {params.mapcfg[target]}"
    CMD+=" -n {params.cfg[regulonname]}"
    CMD+=" -m {input.metadir}/{wildcards.name}_direct_e_regulon_metadata.txt.gz"
    CMD+=" -q {params.cfg[qthr]}"
    CMD+=" -r {params.cfg[rhothr]}"
    CMD+=" -c {params.cfg[region_count]}"
    CMD+=" -- {input.infile}"

    echo "Start running: $CMD"
    eval "$CMD"
    echo "Finish running: $CMD"
    """

rule scenicplush5mu2eregulonheatmap:
  input:
    indir="ataccistopic2runscenicpluspipeline/{name}",
    done="ataccistopic2runscenicpluspipeline/{name}.done",
  output:
    outfile="scenicplush5mu2eregulonheatmap/{name}.pdf",
  wildcard_constraints:
    name="[^/]+",
  params:
    obscfg=config['scrnah5adduplicateobs'],
    cfg=config['scenicplush5mu2eregulonheatmap'],
  shell:
    """
    outdir=$(dirname "{output.outfile}")

    CMD="scenicplush5mu2eregulonheatmap"
    [ "{params.cfg[condaenv]}" != "None" ] && CMD+=" -e {params.cfg[condaenv]}"
    CMD+=" -d $outdir"
    CMD+=" -b {wildcards.name}"
    CMD+=" -l {params.obscfg[key]}"
    CMD+=" -W {params.cfg[width]}"
    CMD+=" -H {params.cfg[height]}"
    CMD+=" -- {input.indir}/scplusmdata.h5mu"

    echo "Start running: $CMD"
    eval "$CMD"
    echo "Finish running: $CMD"
    """

rule scenicplusrsstxt2plotrss:
  input:
    infile="scenicplush5mu2eregulonrss/{name}.txt.gz",
  output:
    outfile="scenicplusrsstxt2plotrss/{name}.pdf",
  wildcard_constraints:
    name="[^/]+",
  params:
    cfg=config['scenicplusrsstxt2plotrss'],
  shell:
    """
    outdir=$(dirname "{output.outfile}")
    datafile=$outdir/{wildcards.name}.txt.gz
    zcat {input.infile} | sed -E 's/_direct_[^[:space:]]+//g; s/_extended_[^[:space:]]+//g' | tofile.sh -o "$datafile"

    CMD="scenicplusrsstxt2plotrss"
    [ "{params.cfg[condaenv]}" != "None" ] && CMD+=" -e {params.cfg[condaenv]}"
    CMD+=" -d $outdir"
    CMD+=" -b {wildcards.name}"
    CMD+=" -m {params.cfg[numcolumn]}"
    CMD+=" -n {params.cfg[ntop]}"
    CMD+=" -W {params.cfg[width]}"
    CMD+=" -H {params.cfg[height]}"
    CMD+=" -- $datafile"

    echo "Start running: $CMD"
    eval "$CMD"
    echo "Finish running: $CMD"
    """
